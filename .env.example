# Copy this file to `.env` and adjust as needed. NEVER commit your real `.env`.
#
# SECRET_KEY is intentionally left OUT of this file. If it is unset (or blank)
# the app mints a strong random ephemeral key at boot, fine for local dev,
# though tokens won't survive a restart. In production, generate and set a
# stable value:
#   SECRET_KEY=$(python -c "import secrets; print(secrets.token_urlsafe(48))")

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite for local dev; swap for e.g. postgresql+psycopg://user:pass@host/db in prod.
DATABASE_URL=sqlite:///./app.db
SQL_ECHO=false

# CORS is parsed as JSON, e.g. ["https://app.example.com","http://localhost:3000"]
CORS_ORIGINS=["*"]
